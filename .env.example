# Public URL used by the browser to reach the API. Leave empty until local infrastructure exists.
NEXT_PUBLIC_API_URL=

# API listener settings. Values are intentionally omitted from this public template.
API_HOST=
API_PORT=

# Authoritative PostgreSQL connection URL. Supply it through local secret management.
DATABASE_URL=

# Redis connection URL used by background job transport. Supply it through local secret management.
REDIS_URL=
