# Public-safe local development defaults only. Never reuse these credentials outside local Compose.
POSTGRES_DB=airline_manager
POSTGRES_USER=airline_manager
POSTGRES_PASSWORD=airline_manager_local_only

# Host ports and browser-visible API URL for the local topology.
WEB_PORT=3000
API_PORT=3001
WORKER_HEALTH_PORT=3002
MAILPIT_WEB_PORT=8025
POSTGRES_PORT=5432
REDIS_PORT=6379
NEXT_PUBLIC_API_URL=http://localhost:3001
API_INTERNAL_URL=http://localhost:3001
NEXT_PUBLIC_MAP_STYLE_URL=

# Authentication secrets and provider credentials are intentionally blank. Generate a local
# Better Auth secret with `openssl rand -base64 32`; never commit the resulting .env file.
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_SECRET=
AUTH_COOKIE_SECURE=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Authentication email delivery for an API process running directly on the host. Local Compose
# overrides the host with its internal Mailpit service; production must provide its own SMTP endpoint.
AUTH_EMAIL_SMTP_HOST=localhost
AUTH_EMAIL_SMTP_PORT=1025
AUTH_EMAIL_SMTP_SECURE=false
AUTH_EMAIL_FROM=Airline Manager <no-reply@airline-manager.test>
AUTH_EMAIL_SMTP_USERNAME=
AUTH_EMAIL_SMTP_PASSWORD=

# Use these URLs when running API or worker processes directly on the host.
API_HOST=127.0.0.1
WORKER_HEALTH_HOST=127.0.0.1
DATABASE_URL=postgresql://airline_manager:airline_manager_local_only@localhost:5432/airline_manager
API_DATABASE_POOL_MAX=20
WORKER_DATABASE_POOL_MAX=10
API_CORS_ORIGINS=http://localhost:3000
API_RATE_LIMIT_MAX=120
API_SSE_HEARTBEAT_MS=15000
DATABASE_CONNECT_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_STATEMENT_TIMEOUT_MS=15000
REDIS_URL=redis://localhost:6379
