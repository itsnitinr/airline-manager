{
  "name": "@airline-manager/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "contract:check": "node --import tsx scripts/generate-contract.mts check",
    "contract:generate": "node --import tsx scripts/generate-contract.mts write",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@airline-manager/application": "workspace:*",
    "@airline-manager/config": "workspace:*",
    "@airline-manager/contracts": "workspace:*",
    "@airline-manager/database": "workspace:*",
    "@fastify/cors": "11.3.0",
    "@fastify/helmet": "13.1.0",
    "@fastify/rate-limit": "11.1.0",
    "@fastify/swagger": "9.8.0",
    "fastify": "5.10.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.99.0",
    "@types/node": "catalog:",
    "rimraf": "6.1.3",
    "tsx": "4.23.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
